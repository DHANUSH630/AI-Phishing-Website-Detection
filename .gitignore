# Git Ignore for AI Phishing Shield

# OS Files
.DS_Store
Thumbs.db

# Extension local storage / caches
extension/ml/model.json.tmp
extension/ml/weights.bin.tmp

# Python ML Pipeline Caches & Artifacts
ml/__pycache__/
ml/*.pyc
ml/data/
ml/models/
ml/plots/
ml/export/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
